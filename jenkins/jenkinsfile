pipeline {
    agent any
    options {
        skipStagesAfterUnstable()
    }
    stages {
        stage('Build') {
            steps {           
                echo 'Setting up Wilma...'
                sh 'docker-compose -f docker-compose.yml up'
                echo 'Building'
                sh 'python3 app.py'
            }
        }
    }
}