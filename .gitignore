.DS_Store
Thumbs.db

# Ignore log files
*.log

# Ignore test and coverage reports
*.cover
*.coverage
*.tox
*.nox
*.coverage
*.hypothesis

# Ignore package distribution files
*.tar.gz
*.egg
*.dist-info/

